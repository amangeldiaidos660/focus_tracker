---
import { iconSvg } from '../../shared/icons';
import '../../styles/dashboard-fixes.css';
---

<section class="panel focus-card">
  <div class="focus-ring clock-only">
    <div class="focus-ring-content">
      <strong id="dashboard-current-time" class="focus-ring-time">00:00</strong>
    </div>
  </div>

  <div class="focus-actions single-action">
    <button id="open-session" data-open-session class="button-primary" type="button">
      <span set:html={iconSvg('play')}></span>
      Начать фокус
    </button>
  </div>
</section>

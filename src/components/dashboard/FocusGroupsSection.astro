---
import { iconSvg } from '../../shared/icons';
---

<section class="panel groups-panel">
  <div class="section-header">
    <h2 class="section-title">Фокус-группы</h2>
    <button id="open-group-form" class="button-primary px-3 py-2 text-xs" type="button">
      <span set:html={iconSvg('plus')}></span>
      Добавить группу
    </button>
  </div>

  <div id="groups-loading" class="loading-state">Загрузка групп...</div>

  <div id="groups-empty" class="empty-state hidden">
    Создайте первую фокус-группу и добавьте в неё учебные ресурсы.
  </div>

  <div id="groups-list" class="groups-list"></div>
</section>

---
import { iconSvg } from '../../shared/icons';
---

<section id="timer-overlay" class="timer-overlay hidden">
  <div class="timer-workspace timer-workspace-simple">
    <div class="timer-center timer-center-only">
      <p id="timer-mode" class="timer-mode">На время · Фокус активен</p>
      <div id="timer-clock" class="timer-clock">25:00</div>
      <p id="timer-message" class="timer-message">
        Сохраняйте внимание на выбранном ресурсе
      </p>

      <div id="timer-next-break-card" class="next-break-card hidden">
        <span id="timer-next-break-label">Следующий перерыв</span>
        <strong id="timer-next-break">00:00</strong>
      </div>

      <div class="timer-controls">
        <button id="timer-pause" class="button-secondary" type="button">
          <span set:html={iconSvg('pause')}></span>
          Пауза
        </button>
        <button id="timer-resume" class="button-primary hidden" type="button">
          <span set:html={iconSvg('play')}></span>
          Продолжить
        </button>
        <button id="timer-stop" class="button-danger" type="button">
          <span set:html={iconSvg('stop')}></span>
          Завершить
        </button>
      </div>
    </div>
  </div>
</section>

<section
  id="timer-overlay"
  class="fixed inset-0 z-[60] hidden min-h-screen items-center justify-center bg-slate-950 px-4"
>
  <div class="w-full max-w-xl text-center">
    <p
      id="timer-mode"
      class="text-sm font-medium uppercase tracking-[0.25em] text-blue-400"
    >
      На время · Фокус
    </p>

    <h2 id="timer-task-title" class="mt-3 text-2xl font-semibold"></h2>
    <p id="timer-group-title" class="mt-1 text-slate-400"></p>
    <div
      id="timer-clock"
      class="my-10 font-mono text-7xl font-semibold tracking-tight sm:text-8xl"
    >
      25:00
    </div>
    <p id="timer-message" class="mb-8 text-sm text-slate-400"></p>

    <div class="flex flex-wrap justify-center gap-3">
      <button id="timer-pause" class="button-secondary px-6 py-3">
        Пауза
      </button>
      <button id="timer-resume" class="button-primary hidden px-6 py-3">
        Продолжить
      </button>
      <button
        id="timer-stop"
        class="rounded-lg bg-red-600 px-6 py-3 font-medium text-white hover:bg-red-500"
      >
        Закончить
      </button>
    </div>
  </div>
</section>

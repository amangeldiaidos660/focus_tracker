---
import { iconSvg } from '../../shared/icons';
---

<section class="panel stats-panel">
  <div class="section-header">
    <h2 class="section-title">Статистика</h2>
    <select id="stats-period" class="period-select" aria-label="Период статистики">
      <option value="week">Неделя</option>
      <option value="month">Месяц</option>
      <option value="year">Год</option>
    </select>
  </div>

  <div class="stats-grid">
    <article class="stat-card">
      <p class="stat-label">Общее время</p>
      <p id="stat-period-total" class="stat-value">0 мин</p>
      <p id="stat-period-change" class="stat-change">Нет данных за прошлый период</p>
    </article>

    <article class="stat-card">
      <div class="section-kicker">
        <span set:html={iconSvg('chart')}></span>
        <span id="bar-chart-title">Время по дням</span>
      </div>
      <div id="weekly-bars" class="bar-chart"></div>
    </article>

    <article class="stat-card">
      <p class="stat-label">Распределение по группам</p>
      <div class="distribution-layout">
        <div id="group-distribution-chart" class="donut-chart"></div>
        <div id="group-distribution-legend" class="distribution-legend"></div>
      </div>
    </article>
  </div>

  <div class="activity-panel">
    <div class="activity-header">
      <div class="section-kicker">
        <span set:html={iconSvg('layers')}></span>
        Активность за год
      </div>
      <select id="activity-year" class="period-select activity-year-select" aria-label="Год активности"></select>
    </div>

    <div class="activity-scroll">
      <div id="activity-chart" class="activity-chart">
        <div id="activity-months" class="activity-months"></div>
        <div class="activity-layout">
          <div class="activity-weekdays" aria-hidden="true">
            <span>Пн</span><span></span><span>Ср</span><span></span><span>Пт</span><span></span><span>Вс</span>
          </div>
          <div id="activity-heatmap" class="activity-heatmap"></div>
        </div>
      </div>
    </div>

    <div class="heatmap-footer" aria-hidden="true">
      <span>Меньше</span>
      <span class="heat-cell heat-level-0"></span>
      <span class="heat-cell heat-level-1"></span>
      <span class="heat-cell heat-level-2"></span>
      <span class="heat-cell heat-level-3"></span>
      <span class="heat-cell heat-level-4"></span>
      <span>Больше</span>
    </div>
  </div>
</section>

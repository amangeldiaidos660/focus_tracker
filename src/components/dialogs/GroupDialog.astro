---
import { iconSvg } from '../../shared/icons';
---

<dialog id="group-dialog" class="app-dialog">
  <form id="group-form" class="dialog-card">
    <div class="dialog-header">
      <h2 class="dialog-title">Создать фокус-группу</h2>
      <button type="button" data-close-dialog="group-dialog" class="dialog-close" aria-label="Закрыть">
        <span set:html={iconSvg('x')}></span>
      </button>
    </div>

    <label class="mt-6 block">
      <span class="field-label">Название группы</span>
      <input id="group-title" class="field-input" maxlength="100" required placeholder="Например: Изучение Python" />
    </label>

    <div class="dialog-actions">
      <button type="button" data-close-dialog="group-dialog" class="button-secondary">Отмена</button>
      <button type="submit" class="button-primary">Создать</button>
    </div>
  </form>
</dialog>

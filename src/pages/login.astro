---
import '../styles/dashboard-fixes.css';
import '../styles/global.css';
---

<!doctype html>
<html lang="ru" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#050914" />
    <title>Вход — Focus Tracker</title>
  </head>

  <body>
    <main class="login-page">
      <section class="login-card">
        <div class="login-brand">
          <span class="brand-mark"></span>
          <span>Focus Tracker</span>
        </div>

        <div class="login-heading">
          <span class="login-kicker">Добро пожаловать</span>
          <h1>Сосредоточьтесь на том, что действительно важно</h1>
          <p>Войдите, чтобы продолжить работу со своими группами, ресурсами и статистикой.</p>
        </div>

        <button id="btn-google-login" class="google-login-button" type="button">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M21.6 12.2c0-.7-.1-1.4-.2-2H12v3.8h5.4a4.6 4.6 0 0 1-2 3v2.5h3.2c1.9-1.7 3-4.3 3-7.3Z"/>
            <path fill="#34A853" d="M12 22c2.7 0 5-.9 6.6-2.5l-3.2-2.5c-.9.6-2 1-3.4 1-2.6 0-4.8-1.8-5.6-4.1H3.1v2.6A10 10 0 0 0 12 22Z"/>
            <path fill="#FBBC05" d="M6.4 13.9a6 6 0 0 1 0-3.8V7.5H3.1a10 10 0 0 0 0 9l3.3-2.6Z"/>
            <path fill="#EA4335" d="M12 6c1.5 0 2.8.5 3.8 1.5l2.9-2.8A9.7 9.7 0 0 0 3.1 7.5l3.3 2.6C7.2 7.8 9.4 6 12 6Z"/>
          </svg>
          Продолжить с Google
        </button>

        <p id="login-error" class="login-error hidden"></p>
        <p class="login-note">Ваши данные синхронизируются только после авторизации.</p>
      </section>
    </main>

    <script>
      import { supabaseClient } from '../lib/supabaseClient';
      import { ensureProfile } from '../lib/ensureProfile';

      const { data } = await supabaseClient.auth.getSession();

      if (data.session?.user) {
        await ensureProfile();
        window.location.replace('/');
      }

      document
        .getElementById('btn-google-login')
        ?.addEventListener('click', async () => {
          const errorElement = document.getElementById('login-error');
          const { error } = await supabaseClient.auth.signInWithOAuth({
            provider: 'google',
            options: { redirectTo: window.location.origin }
          });

          if (error && errorElement) {
            errorElement.textContent = 'Не удалось начать вход через Google.';
            errorElement.classList.remove('hidden');
          }
        });
    </script>
  </body>
</html>

---
import '../styles/global.css';
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Настройки — Focus Tracker</title>
  </head>

  <body class="min-h-screen bg-slate-950 text-slate-100">
    <main class="mx-auto max-w-2xl px-4 py-8 sm:px-6">
      <a href="/" class="text-sm text-blue-400 hover:text-blue-300">
        ← На главную
      </a>

      <h1 class="mt-5 text-3xl font-semibold">Настройки</h1>

      <section class="mt-6 rounded-xl border border-slate-800 bg-slate-900 p-5">
        <h2 class="font-semibold">Уведомления</h2>
        <p class="mt-2 text-sm text-slate-400">
          Получайте сигнал о завершении фокуса, начале и окончании перерыва.
        </p>

        <label class="mt-5 flex items-start justify-between gap-5">
          <span>
            <span class="block font-medium">Системные уведомления</span>
            <span id="notification-permission" class="mt-1 block text-sm text-slate-400"></span>
          </span>
          <input
            id="notifications-enabled"
            type="checkbox"
            class="mt-1 h-5 w-5 shrink-0 accent-blue-500"
          />
        </label>

        <label class="mt-5 flex items-start justify-between gap-5 border-t border-slate-800 pt-5">
          <span>
            <span class="block font-medium">Звуковые сигналы</span>
            <span class="mt-1 block text-sm text-slate-400">
              Работают независимо от разрешения системных уведомлений.
            </span>
          </span>
          <input
            id="sound-enabled"
            type="checkbox"
            class="mt-1 h-5 w-5 shrink-0 accent-blue-500"
          />
        </label>
      </section>

      <section class="mt-6 rounded-xl border border-slate-800 bg-slate-900 p-5">
        <h2 class="font-semibold">Аккаунт</h2>
        <p id="account-email" class="mt-2 text-sm text-slate-400"></p>

        <button
          id="btn-signout"
          class="mt-5 rounded-lg bg-red-600 px-4 py-2 font-medium text-white hover:bg-red-500"
        >
          Выйти из аккаунта
        </button>
      </section>
    </main>

    <script src="../scripts/settings.ts"></script>
  </body>
</html>

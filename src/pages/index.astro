---
import DashboardHeader from '../components/dashboard/DashboardHeader.astro';
import FocusGroupsSection from '../components/dashboard/FocusGroupsSection.astro';
import Notice from '../components/dashboard/Notice.astro';
import SessionStartCard from '../components/dashboard/SessionStartCard.astro';
import StatisticsSection from '../components/dashboard/StatisticsSection.astro';
import TimerOverlay from '../components/dashboard/TimerOverlay.astro';
import GroupDialog from '../components/dialogs/GroupDialog.astro';
import SessionDialog from '../components/dialogs/SessionDialog.astro';
import TaskDialog from '../components/dialogs/TaskDialog.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#050914" />
    <title>Focus Tracker</title>
  </head>

  <body>
    <main id="app" class="app-shell">
      <DashboardHeader />
      <div class="dashboard-grid">
        <SessionStartCard />
        <FocusGroupsSection />
      </div>
      <StatisticsSection />
    </main>

    <Notice />
    <GroupDialog />
    <TaskDialog />
    <SessionDialog />
    <TimerOverlay />

    <script src="../scripts/app.ts"></script>
  </body>
</html>
